BASE_URL=localhost
PORT=8080
GIN_MODE=debug
{{- if ne .Database.String "none" }}
DATABASE_CONN_STRING={{.Database.ConnString .Name }}
{{- end }}
{{- if .SMTP }}

# SMTP
SMTP_HOST=
SMTP_PORT=3000
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
{{- end }}
{{- if .Storage }}

# S3 Storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
{{- end }}
{{- if eq .KeyValueStore "redis" }}

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
{{- else if eq .KeyValueStore "valkey" }}

# Valkey
VALKEY_ADDR=localhost:6379
VALKEY_PASSWORD=
VALKEY_DB=0
{{- end }}
